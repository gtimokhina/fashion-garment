# Your OpenAI API Key
OPENAI_API_KEY=
# Your Pexels API Key
PEXELS_API_KEY= 
# Next.js API URL
NEXT_PUBLIC_API_URL=http://localhost:8000
# OpenAI Model
OPENAI_MODEL=gpt-4o
# OpenAI Embedding Model
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Semantic Search Min Score
# Min cosine similarity (0–1) to keep a semantic hit; also require score >= RELATIVE × best match
SEMANTIC_SEARCH_MIN_SCORE=0.28
SEMANTIC_SEARCH_RELATIVE_TO_BEST=0.88
# Hybrid: 0.5*keyword + 0.5*embedding; drop rows below this combined score
HYBRID_MIN_COMBINED_SCORE=0.25
# Optional: eval LLM-as-judge (eval/run_eval.py --llm-judge); defaults to OPENAI_MODEL
EVAL_JUDGE_MODEL=gpt-4o-mini