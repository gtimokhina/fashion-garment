# Copy to `.env` at the project root. Never commit real keys or paste secrets into this example file.

# --- OpenAI ---
# OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Optional: eval LLM-as-judge (eval/run_eval.py --llm-judge)
# EVAL_JUDGE_MODEL=gpt-4o-mini

# Semantic / hybrid search (defaults match code)
# SEMANTIC_SEARCH_MIN_SCORE=0.28
# SEMANTIC_SEARCH_RELATIVE_TO_BEST=0.88
# HYBRID_MIN_COMBINED_SCORE=0.25

# Local uvicorn (default: SQLite under app/backend/data/)
# DATABASE_URL=sqlite:///./data/app.db
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional: eval/scripts/download_pexels_fashion.py
# PEXELS_API_KEY=

# Docker Compose + Next build (browser → API on host)
NEXT_PUBLIC_API_URL=http://localhost:8000
# BACKEND_PORT=8000
# FRONTEND_PORT=3000

# Next.js dev (`npm run dev`) reads app/frontend/.env.local — copy NEXT_PUBLIC_* there if needed.
