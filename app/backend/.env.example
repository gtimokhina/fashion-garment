# Copy to .env in this directory. The app loads .env automatically (python-dotenv).
# DATABASE_URL=sqlite:///./data/app.db
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# OpenAI (for classify_image — never commit real keys)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small   # semantic search on descriptions
# SEMANTIC_SEARCH_MIN_SCORE=0.28                  # min cosine similarity (0–1) to keep a result
# SEMANTIC_SEARCH_RELATIVE_TO_BEST=0.88           # also require score >= this × best match

# Pexels (optional — eval/scripts/download_pexels_fashion.py reads this file)
# PEXELS_API_KEY=
